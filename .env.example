# Copy this file to .env and fill in your real keys:
#   cp .env.example .env

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Tavily API key (https://tavily.com - free tier available)
TAVILY_API_KEY=tvly-your-key-here

# Slack Incoming Webhook (https://api.slack.com/messaging/webhooks)
# Set SLACK_ENABLED=true to push the briefing to Slack after generation.
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# AgentOps observability (https://app.agentops.ai)
# Set AGENTOPS_ENABLED=true to trace runs to the dashboard.
AGENTOPS_ENABLED=false
AGENTOPS_API_KEY=your-agentops-key

# (Optional) LLM model to use - the default is fine
# LLM_MODEL=anthropic/claude-sonnet-4-6

# (Optional) Output token budget. Must be large enough to cover reasoning
# ("thinking") tokens plus the actual answer - too small causes intermittent
# truncated-response failures. The 16384 default is a safe ceiling.
# LLM_MAX_TOKENS=16384
